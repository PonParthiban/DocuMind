# Hugging Face Access Token (Required for Hugging Face Inference LLM APIs)
HF_TOKEN=your_huggingface_token_here

# Hugging Face Model Identifier Configurations
MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
EMBED_MODEL_ID=all-MiniLM-L6-v2

# Storage Directories (Absolute paths recommended for volume mounts in Docker)
DATA_DIR=/app/data
STORAGE_DIR=/app/storage

# CORS Configuration (Comma-separated list of allowed origins)
# Example: https://documind.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=*
